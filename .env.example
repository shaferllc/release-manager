# Copy to .env and set values for local development.
# When Settings → License server environment is "Development", the app uses this URL (https://shipwell-web.test)
# but still needs a Passport password-grant client. Create one in shipwell-web, then set:

# From: cd shipwell-web && php artisan passport:client --password
# Use the returned Client ID and Secret here so login/register work without entering them in Settings.
LICENSE_DEV_CLIENT_ID=
LICENSE_DEV_CLIENT_SECRET=

# Changelog / Releases view: fetch version history from GitHub (e.g. shaferllc/shipwell).
# Use owner/repo format. Enables "Releases" / version history from GitHub in the Changelog view.
# GITHUB_REPO=shaferllc/shipwell
GITHUB_REPO=

# Production/Staging: only needed when running scripts/generate-license-bundled.js (e.g. in CI before npm run build).
# The generated license-server.bundled.json is packaged so the built app can log in to prod/staging without user config.
# LICENSE_PROD_CLIENT_ID=
# LICENSE_PROD_CLIENT_SECRET=
# LICENSE_STAGING_CLIENT_ID=
# LICENSE_STAGING_CLIENT_SECRET=
