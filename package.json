{
  "name": "release-manager",
  "version": "0.4.3",
  "productName": "Release Manager",
  "description": "Desktop app to manage releases for all your app projects",
  "main": "src-main/main.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "node scripts/ensure-icon.js && npm run build:css && node tests/e2e/smoke.js",
    "start": "node scripts/ensure-icon.js && node scripts/generate-icons.js && npm run build:css && electron .",
    "dev": "node scripts/ensure-icon.js && node scripts/generate-icons.js && npm run build:css && NODE_ENV=development electron . --enable-logging",
    "watch": "node scripts/ensure-icon.js && nodemon",
    "build:css": "npx tailwindcss -i ./src-renderer/input.css -o ./src-renderer/styles.css",
    "watch:css": "npx tailwindcss -i ./src-renderer/input.css -o ./src-renderer/styles.css --watch",
    "ensure-icon": "node scripts/ensure-icon.js",
    "generate-icons": "node scripts/generate-icons.js",
    "build": "node scripts/ensure-icon.js && node scripts/generate-icons.js && npm run build:css && npx electron-builder",
    "build:mac": "npx electron-builder --mac",
    "build:win": "npx electron-builder --win",
    "build:linux": "npx electron-builder --linux",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "keywords": [
    "release",
    "version",
    "git",
    "npm",
    "desktop"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.releasemanager.app",
    "productName": "Release Manager",
    "copyright": "Copyright © Release Manager",
    "publish": null,
    "directories": {
      "output": "dist",
      "buildResources": "assets/icons"
    },
    "files": [
      "src-main/**",
      "src-renderer/**",
      "assets/**",
      "scripts/**",
      "node_modules/**",
      "package.json",
      "CHANGELOG.md"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icons/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "assets/icons/icon.png"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "marked": "^15.0.0",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "playwright": "^1.49.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.19"
  }
}
