{
  "name": "shipwell",
  "version": "0.9.0",
  "productName": "Shipwell",
  "description": "Desktop app to manage releases for all your app projects",
  "main": "src-main/main.js",
  "scripts": {
    "test": "npm run test:main && npm run test:vue",
    "test:main": "jest",
    "test:main:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "npm run test:main:coverage && npm run test:vue:coverage",
    "test:vue": "cd renderer-vue && npm run test:run",
    "test:vue:coverage": "cd renderer-vue && npm run test:coverage",
    "test:e2e": "node scripts/ensure-icon.js && node scripts/generate-icons.js && npm run build:renderer-vue && node tests/e2e/smoke.js",
    "start": "node scripts/ensure-icon.js && node scripts/generate-icons.js && npm run build:renderer-vue && electron .",
    "restart": "npm start",
    "dev": "node scripts/ensure-icon.js && node scripts/generate-icons.js && npm run build:renderer-vue && NODE_ENV=development electron . --enable-logging",
    "build:css": "npx tailwindcss -i ./src-renderer/input.css -o ./src-renderer/styles.css",
    "watch:css": "npx tailwindcss -i ./src-renderer/input.css -o ./src-renderer/styles.css --watch",
    "ensure-icon": "node scripts/ensure-icon.js",
    "generate-icons": "node scripts/generate-icons.js",
    "build:js": "esbuild src-renderer/main.js --bundle --outfile=src-renderer/renderer.js",
    "build:renderer-vue": "node scripts/prepare-renderer-vue-public.js && cd renderer-vue && npm install && npm run build",
    "watch:renderer-vue": "cd renderer-vue && npm run build:watch",
    "dev:vue": "node scripts/ensure-icon.js && node scripts/generate-icons.js && npm run build:renderer-vue && concurrently \"npm run watch:renderer-vue\" \"electron .\"",
    "start:vue": "npm run build:renderer-vue && USE_VUE_RENDERER=1 electron .",
    "build": "node scripts/ensure-icon.js && node scripts/generate-icons.js && npm run build:renderer-vue && npx electron-builder",
    "build:mac": "npx electron-builder --mac",
    "build:win": "npx electron-builder --win",
    "build:linux": "npx electron-builder --linux",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "mcp": "node scripts/run-mcp.js",
    "mcp:install": "npm install --prefix mcp-server"
  },
  "keywords": [
    "release",
    "version",
    "git",
    "npm",
    "desktop"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.shipwell.app",
    "productName": "Shipwell",
    "copyright": "Copyright © Shipwell",
    "publish": null,
    "directories": {
      "output": "dist",
      "buildResources": "assets/icons"
    },
    "files": [
      "src-main/**",
      "dist-renderer/**",
      "assets/**",
      "scripts/**",
      "node_modules/**",
      "package.json",
      "CHANGELOG.md"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icons/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "assets/icons/icon.png"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "marked": "^15.0.0",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "playwright": "^1.49.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.19"
  }
}
